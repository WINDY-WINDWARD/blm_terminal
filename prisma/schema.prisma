// Prisma schema for BLM Terminal
// SQLite datasource for local persistence

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model WatchlistItem {
  id        Int      @id @default(autoincrement())
  symbol    String
  exchange  String
  createdAt DateTime @default(now())

  @@unique([symbol, exchange])
}

model TopMoverSymbol {
  id       Int    @id @default(autoincrement())
  symbol   String
  exchange String

  @@unique([symbol, exchange])
}
