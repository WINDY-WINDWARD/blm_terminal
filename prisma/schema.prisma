// Prisma schema for BLM Terminal
// SQLite datasource for local persistence

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model WatchlistItem {
  id        Int      @id @default(autoincrement())
  symbol    String
  exchange  String
  createdAt DateTime @default(now())

  @@unique([symbol, exchange])
}

model TopMoverSymbol {
  id       Int    @id @default(autoincrement())
  symbol   String
  exchange String

  @@unique([symbol, exchange])
}

model UserSettings {
  id               Int      @id @default(1)
  watchlistColumns String   @default("[\"ltp\",\"chg\",\"1w\",\"1m\",\"3m\",\"6m\",\"1y\"]")
  moversColumns    String   @default("[\"close\",\"chg\",\"1w\",\"1m\",\"3m\",\"6m\",\"1y\"]")
  updatedAt        DateTime @updatedAt
}
